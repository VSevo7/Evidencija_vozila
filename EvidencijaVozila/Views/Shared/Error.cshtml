@model EvidencijaVozila.Models.ErrorViewModel
@{
    ViewData["Title"] = "Pogreška";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-danger">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Dogodila se pogreška</h1>
                <p class="text-muted mb-0">Došlo je do pogreške tijekom rada aplikacije. Pokušaj ponovno, a ako se problem nastavi provjeri vezu s bazom i konfiguraciju projekta.</p>
                @if (Model.ShowRequestId)
                {
                    <p class="small text-muted mt-3 mb-0">Identifikator zahtjeva: <code>@Model.RequestId</code></p>
                }
            </div>
        </div>
    </div>
</div>
