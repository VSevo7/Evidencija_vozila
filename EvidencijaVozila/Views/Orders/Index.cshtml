@model IEnumerable<EvidencijaVozila.ViewModels.Orders.OrderIndexItemViewModel>
@{
    ViewData["Title"] = "Nalozi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 mb-1">Nalozi</h1>
        <p class="text-muted mb-0">Pregled aktivnih i zavrsenih naloga za upotrebu vozila.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Novi nalog</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Broj naloga</th><th>Vozilo</th><th>Vozac</th><th>Jedinica</th><th>Termin</th><th>Status</th><th class="text-end">Detalji</th></tr></thead>
            <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderNumber</td>
                    <td>@order.Vehicle</td>
                    <td>@order.Driver</td>
                    <td>@order.OrganizationalUnit</td>
                    <td>@order.DepartureAt.ToString("dd.MM.yyyy HH:mm")<br /><small>@order.ReturnAt.ToString("dd.MM.yyyy HH:mm")</small></td>
                    <td><span class="badge text-bg-@ViewHelpers.BadgeClass(order.Status)">@order.Status</span></td>
                    <td class="text-end"><a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Detalji</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
