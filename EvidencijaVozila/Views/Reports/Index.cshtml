@model EvidencijaVozila.ViewModels.Reports.ReportsViewModel
@{
    ViewData["Title"] = "Izvjestaji";
}

<div class="mb-4">
    <h1 class="h2 mb-1">Izvjestaji</h1>
    <p class="text-muted mb-0">Pregled koristenja vozila, vozaca i servisnih intervala.</p>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100"><div class="card-body"><h2 class="h5">Koristenje po vozilu</h2><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Vozilo</th><th>Nalozi</th><th>Km</th></tr></thead><tbody>@foreach (var row in Model.UsageByVehicle) { <tr><td>@row.Vehicle</td><td>@row.OrderCount</td><td>@row.TotalKm</td></tr> }</tbody></table></div></div></div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm h-100"><div class="card-body"><h2 class="h5">Koristenje po vozacu</h2><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Vozac</th><th>Jedinica</th><th>Nalozi</th></tr></thead><tbody>@foreach (var row in Model.UsageByDriver) { <tr><td>@row.Driver</td><td>@row.OrganizationalUnit</td><td>@row.OrderCount</td></tr> }</tbody></table></div></div></div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm h-100"><div class="card-body"><h2 class="h5">Nalozi po jedinici</h2><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Jedinica</th><th>Nalozi</th></tr></thead><tbody>@foreach (var row in Model.UsageByUnit) { <tr><td>@row.OrganizationalUnit</td><td>@row.OrderCount</td></tr> }</tbody></table></div></div></div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm h-100"><div class="card-body"><h2 class="h5">Servisni pregled</h2><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Vozilo</th><th>Trenutno km</th><th>Km do servisa</th></tr></thead><tbody>@foreach (var row in Model.ServiceReport) { <tr><td>@row.Vehicle</td><td>@row.CurrentMileage</td><td>@row.KmUntilService</td></tr> }</tbody></table></div></div></div>
    </div>
</div>
