@model EvidencijaVozila.ViewModels.Availability.AvailabilitySearchViewModel
@{
    ViewData["Title"] = "Dostupnost vozila";
}

<div class="mb-4">
    <h1 class="h2 mb-1">Pregled dostupnosti vozila</h1>
    <p class="text-muted mb-0">Pretraga slobodnih vozila u zadanom terminu.</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Search" method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger col-12"></div>
            <div class="col-md-4"><label asp-for="DepartureAt" class="form-label"></label><input asp-for="DepartureAt" type="datetime-local" class="form-control" value="@(Model.DepartureAt?.ToString("yyyy-MM-ddTHH:mm"))" /></div>
            <div class="col-md-4"><label asp-for="ReturnAt" class="form-label"></label><input asp-for="ReturnAt" type="datetime-local" class="form-control" value="@(Model.ReturnAt?.ToString("yyyy-MM-ddTHH:mm"))" /></div>
            <div class="col-md-4"><label asp-for="VehicleType" class="form-label"></label><select asp-for="VehicleType" asp-items="Html.GetEnumSelectList<VehicleType>()" class="form-select"><option value="">Sve vrste</option></select></div>
            <div class="col-md-4"><button type="submit" class="btn btn-primary w-100">Provjeri dostupnost</button></div>
        </form>
    </div>
</div>

@if (Model.SearchPerformed)
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead><tr><th>Registracija</th><th>Marka i tip</th><th>Vrsta</th><th>Gorivo</th><th>Mjenjac</th><th>Gume</th><th>Status</th></tr></thead>
                <tbody>
                @if (!Model.Results.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Nema slobodnih vozila u trazenom terminu.</td></tr>
                }
                @foreach (var vehicle in Model.Results)
                {
                    <tr>
                        <td>@vehicle.RegistrationNumber</td>
                        <td>@vehicle.BrandModel</td>
                        <td>@vehicle.VehicleType</td>
                        <td>@vehicle.FuelType</td>
                        <td>@vehicle.TransmissionType</td>
                        <td>@vehicle.CurrentTires</td>
                        <td><span class="badge text-bg-@ViewHelpers.BadgeClass(vehicle.Status)">@vehicle.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
