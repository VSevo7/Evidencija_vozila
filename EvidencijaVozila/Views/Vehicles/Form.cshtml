@model EvidencijaVozila.ViewModels.Vehicles.VehicleFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Uredi vozilo" : "Dodaj vozilo";
}

<div class="d-flex justify-content-between align-items-center mb-4 app-page-head">
    <div class="app-page-head-main">
        <a asp-controller="Dashboard" asp-action="Index" class="app-home-back" aria-label="Povratak na početnu">&larr;</a>
        <div>
            <h1 class="h2 mb-0">@ViewData["Title"]</h1>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Natrag</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="@(Model.Id.HasValue ? "Edit" : "Create")" asp-route-id="@Model.Id" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="RegistrationNumber" class="form-label"></label>
                    <input asp-for="RegistrationNumber" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label asp-for="BrandModel" class="form-label"></label>
                    <input asp-for="BrandModel" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="VehicleType" class="form-label"></label>
                    <select asp-for="VehicleType" asp-items="Html.GetEnumSelectList<VehicleType>()" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="CurrentTires" class="form-label"></label>
                    <select asp-for="CurrentTires" class="form-select">
                        <option value="">Odaberi gume</option>
                        <option value="Ljetne">Ljetne</option>
                        <option value="Zimske">Zimske</option>
                        <option value="Cjelogodišnje">Cjelogodišnje</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="CurrentMileage" class="form-label"></label>
                    <input asp-for="CurrentMileage" type="number" min="0" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<VehicleStatus>()" class="form-select js-status-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="FuelType" class="form-label"></label>
                    <select asp-for="FuelType" asp-items="Html.GetEnumSelectList<FuelType>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="TransmissionType" class="form-label"></label>
                    <select asp-for="TransmissionType" asp-items="Html.GetEnumSelectList<TransmissionType>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="PurchasePrice" class="form-label"></label>
                    <input asp-for="PurchasePrice" asp-format="{0:0}" type="number" min="0" step="1" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label mb-0">Evidencija izmjene guma</label>
                        <button type="button" class="btn btn-sm btn-outline-primary js-add-tire-change">+ Dodaj izmjenu</button>
                    </div>
                    <div class="js-tire-change-list">
                        @for (var i = 0; i < Model.TireChanges.Count; i++)
                        {
                            <div class="row g-2 align-items-end mb-3 tire-change-row">
                                <div class="col-md-4">
                                    <label class="form-label" for="TireChanges_@(i)__ChangedAt">Datum izmjene</label>
                                    <input type="date" class="form-control" data-field="ChangedAt" name="TireChanges[@i].ChangedAt" id="TireChanges_@(i)__ChangedAt" value="@(Model.TireChanges[i].ChangedAt?.ToString("yyyy-MM-dd"))" />
                                    <span asp-validation-for="TireChanges[i].ChangedAt" class="text-danger small" data-field-validation="ChangedAt"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label" for="TireChanges_@(i)__TireType">Tip gume</label>
                                    <select class="form-select" data-field="TireType" name="TireChanges[@i].TireType" id="TireChanges_@(i)__TireType">
                                        <option value="">Odaberi tip gume</option>
                                        <option value="Ljetne" selected="@(Model.TireChanges[i].TireType == "Ljetne")">Ljetne</option>
                                        <option value="Zimske" selected="@(Model.TireChanges[i].TireType == "Zimske")">Zimske</option>
                                        <option value="Cjelogodišnje" selected="@(Model.TireChanges[i].TireType == "Cjelogodišnje")">Cjelogodišnje</option>
                                    </select>
                                    <span asp-validation-for="TireChanges[i].TireType" class="text-danger small" data-field-validation="TireType"></span>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" for="TireChanges_@(i)__MileageAtChange">Stanje km</label>
                                    <input type="number" min="0" class="form-control" data-field="MileageAtChange" name="TireChanges[@i].MileageAtChange" id="TireChanges_@(i)__MileageAtChange" value="@(Model.TireChanges[i].MileageAtChange?.ToString())" />
                                    <span asp-validation-for="TireChanges[i].MileageAtChange" class="text-danger small" data-field-validation="MileageAtChange"></span>
                                </div>
                                <div class="col-md-1 d-grid">
                                    <button type="button" class="btn btn-outline-danger btn-sm js-remove-tire-change">Ukloni</button>
                                </div>
                            </div>
                        }
                    </div>
                    <p class="text-muted small mb-0 js-no-tire-changes" style="display:@(Model.TireChanges.Count == 0 ? "block" : "none");">Nema evidentiranih izmjena guma.</p>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Spremi</button>
            </div>
        </form>
    </div>
</div>

<script type="text/template" id="tire-change-template">
    <div class="row g-2 align-items-end mb-3 tire-change-row">
        <div class="col-md-4">
            <label class="form-label" for="TireChanges___index___ChangedAt">Datum izmjene</label>
            <input type="date" class="form-control" data-field="ChangedAt" name="TireChanges[__index__].ChangedAt" id="TireChanges___index___ChangedAt" />
            <span class="text-danger small field-validation-valid" data-valmsg-for="TireChanges[__index__].ChangedAt" data-field-validation="ChangedAt"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label" for="TireChanges___index___TireType">Tip gume</label>
            <select class="form-select" data-field="TireType" name="TireChanges[__index__].TireType" id="TireChanges___index___TireType">
                <option value="">Odaberi tip gume</option>
                <option value="Ljetne">Ljetne</option>
                <option value="Zimske">Zimske</option>
                <option value="Cjelogodišnje">Cjelogodišnje</option>
            </select>
            <span class="text-danger small field-validation-valid" data-valmsg-for="TireChanges[__index__].TireType" data-field-validation="TireType"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label" for="TireChanges___index___MileageAtChange">Stanje km</label>
            <input type="number" min="0" class="form-control" data-field="MileageAtChange" name="TireChanges[__index__].MileageAtChange" id="TireChanges___index___MileageAtChange" />
            <span class="text-danger small field-validation-valid" data-valmsg-for="TireChanges[__index__].MileageAtChange" data-field-validation="MileageAtChange"></span>
        </div>
        <div class="col-md-1 d-grid">
            <button type="button" class="btn btn-outline-danger btn-sm js-remove-tire-change">Ukloni</button>
        </div>
    </div>
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const statusSelect = document.querySelector('.js-status-select');
            const list = document.querySelector('.js-tire-change-list');
            const addButton = document.querySelector('.js-add-tire-change');
            const emptyState = document.querySelector('.js-no-tire-changes');
            const template = document.getElementById('tire-change-template');

            const syncStatusStyle = () => {
                if (!statusSelect) {
                    return;
                }

                const selectedText = statusSelect.options[statusSelect.selectedIndex]?.text?.toLowerCase() ?? '';
                statusSelect.classList.toggle('status-rashod', selectedText.includes('rashod'));
            };

            const updateEmptyState = () => {
                if (!emptyState || !list) {
                    return;
                }

                emptyState.style.display = list.querySelectorAll('.tire-change-row').length === 0 ? 'block' : 'none';
            };

            const reindexRows = () => {
                if (!list) {
                    return;
                }

                const rows = list.querySelectorAll('.tire-change-row');
                rows.forEach((row, index) => {
                    row.querySelectorAll('[data-field]').forEach(field => {
                        const fieldName = field.getAttribute('data-field');
                        if (!fieldName) {
                            return;
                        }

                        field.setAttribute('name', `TireChanges[${index}].${fieldName}`);
                        field.setAttribute('id', `TireChanges_${index}__${fieldName}`);
                    });

                    row.querySelectorAll('label[for]').forEach(label => {
                        const field = label.parentElement?.querySelector('[data-field]');
                        const fieldName = field?.getAttribute('data-field');
                        if (!fieldName) {
                            return;
                        }

                        label.setAttribute('for', `TireChanges_${index}__${fieldName}`);
                    });

                    row.querySelectorAll('[data-field-validation]').forEach(span => {
                        const fieldName = span.getAttribute('data-field-validation');
                        if (!fieldName) {
                            return;
                        }

                        span.setAttribute('data-valmsg-for', `TireChanges[${index}].${fieldName}`);
                    });
                });
            };

            const addRow = () => {
                if (!list || !template) {
                    return;
                }

                const index = list.querySelectorAll('.tire-change-row').length;
                const markup = template.innerHTML.replaceAll('__index__', index.toString());
                list.insertAdjacentHTML('beforeend', markup);
                reindexRows();
                updateEmptyState();
            };

            if (statusSelect) {
                statusSelect.addEventListener('change', syncStatusStyle);
                syncStatusStyle();
            }

            if (addButton) {
                addButton.addEventListener('click', addRow);
            }

            if (list) {
                list.addEventListener('click', event => {
                    const target = event.target;
                    if (!(target instanceof HTMLElement) || !target.classList.contains('js-remove-tire-change')) {
                        return;
                    }

                    const row = target.closest('.tire-change-row');
                    row?.remove();
                    reindexRows();
                    updateEmptyState();
                });
            }

            updateEmptyState();
        })();
    </script>
}
