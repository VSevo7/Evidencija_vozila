@model IEnumerable<EvidencijaVozila.ViewModels.Users.UserIndexItemViewModel>
@{
    ViewData["Title"] = "Korisnici";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 mb-1">Korisnici</h1>
        <p class="text-muted mb-0">Administracija korisnickih racuna i organizacijske pripadnosti.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Dodaj korisnika</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Ime i prezime</th><th>Korisnicko ime</th><th>Uloga</th><th>Organizacija</th><th>Status</th><th class="text-end">Akcije</th></tr></thead>
            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName<br /><small class="text-muted">@user.Email</small></td>
                    <td>@user.Username</td>
                    <td>@user.Role</td>
                    <td>@user.Organization</td>
                    <td><span class="badge text-bg-@ViewHelpers.BadgeClass(user.Status)">@user.Status</span></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Uredi</a>
                        <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Promijeni status</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
