@model EvidencijaVozila.ViewModels.Orders.OrderFormViewModel
@{
    ViewData["Title"] = "Novi nalog";
}

<div class="d-flex justify-content-between align-items-center mb-4 app-page-head">
    <div class="app-page-head-main">
        <a asp-controller="Dashboard" asp-action="Index" class="app-home-back" aria-label="Povratak na početnu">&larr;</a>
        <div>
            <h1 class="h2 mb-0">Novi nalog</h1>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Natrag</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input asp-for="OrganizationalUnitId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @if (!Model.VehicleOptions.Any())
            {
                <div class="empty-state-message text-center py-5">
                    <h2 class="h4 mb-2">Trenutno nema raspoloživih vozila</h2>
                    <p class="text-muted mb-0">Sva vozila su izdana ili rashodovana. Pokušajte ponovno kasnije.</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="OrderNumber" class="form-label"></label>
                        <input asp-for="OrderNumber" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="VehicleId" class="form-label"></label>
                        <select asp-for="VehicleId" class="form-select js-vehicle-select">
                            <option value="">Odaberi vozilo</option>
                            @foreach (var vehicle in Model.VehicleOptions)
                            {
                                <option value="@vehicle.Id"
                                        data-mileage="@vehicle.CurrentMileage"
                                        selected="@(Model.VehicleId == vehicle.Id ? "selected" : null)">
                                    @vehicle.Label
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DriverId" class="form-label"></label>
                        <select asp-for="DriverId" asp-items="Model.Drivers" class="form-select">
                            <option value="">Odaberi vozača</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Ustrojstvena jedinica</label>
                        <input class="form-control" value="@Model.OrganizationalUnitName" readonly />
                    </div>
                    <div class="col-md-2">
                        <div class="form-check mt-4 pt-2">
                            <input asp-for="IsBusinessTrip" class="form-check-input" />
                            <label asp-for="IsBusinessTrip" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DepartureAt" class="form-label"></label>
                        <input asp-for="DepartureAt" type="datetime-local" class="form-control" value="@Model.DepartureAt.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="MileageBefore" class="form-label"></label>
                        <input asp-for="MileageBefore" type="number" min="0" class="form-control js-mileage-input" readonly />
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Note" class="form-label"></label>
                        <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Kreiraj nalog</button>
                </div>
            }
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const vehicleSelect = document.querySelector('.js-vehicle-select');
            const mileageInput = document.querySelector('.js-mileage-input');

            if (!vehicleSelect || !mileageInput) {
                return;
            }

            const syncMileage = () => {
                const selected = vehicleSelect.options[vehicleSelect.selectedIndex];
                mileageInput.value = selected?.dataset?.mileage ?? '';
            };

            vehicleSelect.addEventListener('change', syncMileage);
            syncMileage();
        })();
    </script>
}
