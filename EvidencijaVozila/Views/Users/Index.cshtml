@model IEnumerable<EvidencijaVozila.ViewModels.Users.UserIndexItemViewModel>
@{
    ViewData["Title"] = "Korisnici";
}

<div class="d-flex justify-content-between align-items-center mb-4 app-page-head">
    <div class="app-page-head-main">
        <a asp-controller="Dashboard" asp-action="Index" class="app-home-back" aria-label="Povratak na početnu">&larr;</a>
        <div>
            <h1 class="h2 mb-0">Korisnici</h1>
        </div>
    </div>
    <a asp-action="Create" class="btn btn-primary">Dodaj korisnika</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Ime i prezime</th>
                    <th>Korisničko ime</th>
                    <th>Uloga</th>
                    <th>Funkcija</th>
                    <th>Organizacija</th>
                    <th>Status</th>
                    <th class="text-end">Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            @user.FullName
                            <br />
                            <small class="text-muted">@user.Email</small>
                            @if (!string.IsNullOrWhiteSpace(user.ContactPhone))
                            {
                                <br />
                                <small class="text-muted">@user.ContactPhone</small>
                            }
                        </td>
                        <td>@user.Username</td>
                        <td>@user.Role</td>
                        <td>@user.Position</td>
                        <td>@user.Organization</td>
                        <td><span class="app-status-badge app-status-@ViewHelpers.BadgeClass(user.Status)">@user.Status</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Uredi</a>
                            <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Promijeni status</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
